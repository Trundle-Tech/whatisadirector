# =========================================================================
# What is a Director - Environment Variables Example
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Google Cloud / Vertex AI Credentials (Electron Main Process)
# Used for Text Embeddings (text-embedding-004) and Gemini Chat (gemini-2.5-flash)
# -------------------------------------------------------------------------
GCP_PROJECT_ID=whatisadirector
GCP_REGION=us-central1
VERTEX_API_KEY=your_google_cloud_vertex_api_key_here

# -------------------------------------------------------------------------
# 2. Firebase Client Configuration (Vite Renderer Process)
# Used by the frontend web SDK to authenticate users and listen to Firestore
# -------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
