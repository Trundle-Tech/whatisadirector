# -------------------------------------------------------------------------
# 1. Google Cloud / Vertex AI Credentials (Electron Main Process)
# Used for Text Embeddings (text-embedding-004) and Gemini Chat (gemini-2.5-flash)
# -------------------------------------------------------------------------
GCP_PROJECT_ID=whatisadirector
GCP_REGION=us-central1
VERTEX_API_KEY=your_google_cloud_vertex_api_key_here

# -------------------------------------------------------------------------
# 2. Firebase Client Configuration (Vite Renderer Process)
# Used by the frontend web SDK to authenticate users and listen to Firestore
# -------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSyAhrZ_FxgfvYtFqeY7KoUUOYrUYYdfAna8
VITE_FIREBASE_AUTH_DOMAIN=whatisadirector.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=whatisadirector
VITE_FIREBASE_STORAGE_BUCKET=whatisadirector.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=452588711956
VITE_FIREBASE_APP_ID=1:452588711956:web:0170dbf47be717da33f701
